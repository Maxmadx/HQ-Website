              "description": "Internal safety reporting"
            },
            {
              "type": "Hazard Report",
              "authority": "Internal",
              "deadline": "as soon as practical",
              "description": "Identification of potential hazards"
            },
            {
              "type": "Ground Incident Report",
              "authority": "Internal",
              "deadline": "24 hours",
              "description": "Ground handling incidents"
            }
          ]
        },
        "risk_assessment": {
          "name": "Risk Assessment",
          "description": "Operational risk assessment tools",
          "assessment_types": [
            "flight_risk_assessment",
            "landing_site_assessment",
            "weather_risk_assessment",
            "fatigue_risk_assessment",
