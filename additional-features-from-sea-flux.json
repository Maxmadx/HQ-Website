    "safety_management": {
      "name": "Safety Management System",
      "description": "Comprehensive safety management and reporting",
      "features": {
        "safety_equipment": {
          "name": "Safety Equipment Tracking",
          "description": "Monitoring of required safety equipment",
          "equipment": [
            {
              "item": "Emergency Locator Transmitter (ELT)",
              "inspection_interval": "12 months",
              "battery_life": "varies"
            },
            {
              "item": "Fire Extinguisher",
              "inspection_interval": "12 months",
              "mandatory": true
            },
            {
              "item": "First Aid Kit",
              "inspection_interval": "12 months",
              "mandatory": true
            },
            {
              "item": "Life Jackets",
              "inspection_interval": "12 months",
              "required_for": "overwater operations"
            },
            {
              "item": "Life Raft",
              "inspection_interval": "12 months",
              "required_for": "extended overwater operations"
            },
            {
              "item": "Survival Kit",
              "inspection_interval": "12 months",
              "required_for": "remote area operations"
            },
            {
              "item": "Emergency Flotation System",
              "inspection_interval": "as per manufacturer",
              "required_for": "overwater operations"
            }
          ]
        },
        "occurrence_reporting": {
