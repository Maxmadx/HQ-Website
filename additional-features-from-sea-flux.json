{
  "system": {
    "name": "HQ Aviation Fleet Management System",
    "description": "Comprehensive aircraft fleet management, maintenance tracking, pilot certification, and regulatory compliance platform adapted from maritime vessel management principles",
    "version": "1.0.0",
    "adapted_from": "Sea-Flux Maritime Vessel Management System"
  },
  "modules": {
    "aircraft_management": {
      "name": "Aircraft Fleet Management",
      "description": "Complete lifecycle management for helicopter and fixed-wing aircraft fleets",
      "features": {
        "aircraft_registry": {
          "name": "Aircraft Registry",
          "description": "Central database of all fleet aircraft with full specifications",
          "fields": [
            "registration_number",
            "aircraft_type",
            "manufacturer",
            "model",
            "serial_number",
            "year_of_manufacture",
            "engine_type",
            "engine_serial_number",
            "maximum_takeoff_weight",
            "useful_load",
            "fuel_capacity",
            "range",
            "cruise_speed",
            "seating_capacity",
            "home_base",
            "owner",
            "operator",
            "insurance_policy",
            "purchase_date",
            "current_status"
          ]
        },
        "flight_hours_tracking": {
          "name": "Flight Hours Tracking",
          "description": "Real-time tracking of airframe, engine, and component flight hours",
          "metrics": [
            "total_airframe_hours",
            "engine_hours_since_new",
            "engine_hours_since_overhaul",
            "cycles_since_new",
            "cycles_since_overhaul",
            "rotor_hours",
            "tail_rotor_hours",
            "component_hours"
          ]
        },
        "aircraft_documents": {
          "name": "Aircraft Documentation",
          "description": "Digital storage and tracking of all required aircraft documentation",
          "document_types": [
            {
              "name": "Certificate of Airworthiness",
              "authority": "CAA",
              "renewal_period": "annual",
              "mandatory": true
            },
            {
              "name": "Certificate of Registration",
              "authority": "CAA",
              "renewal_period": "none",
              "mandatory": true
            },
            {
              "name": "Radio Station Licence",
              "authority": "Ofcom",
              "renewal_period": "5 years",
              "mandatory": true
            },
            {
              "name": "Aircraft Insurance Certificate",
              "authority": "Insurer",
              "renewal_period": "annual",
              "mandatory": true
            },
            {
              "name": "Noise Certificate",
              "authority": "CAA",
              "renewal_period": "none",
              "mandatory": true
            },
            {
              "name": "Weight and Balance Report",
              "authority": "Part 145 Organisation",
              "renewal_period": "as amended",
              "mandatory": true
            },
            {
              "name": "Aircraft Flight Manual",
              "authority": "Manufacturer",
              "renewal_period": "as amended",
              "mandatory": true
            },
            {
              "name": "Minimum Equipment List",
              "authority": "Operator/CAA",
              "renewal_period": "as amended",
              "mandatory": false
            },
            {
              "name": "Technical Log",
              "authority": "Operator",
              "renewal_period": "continuous",
              "mandatory": true
            }
          ]
        },
        "status_tracking": {
          "name": "Aircraft Status Tracking",
          "description": "Real-time operational status monitoring",
          "statuses": [
            "serviceable",
            "unserviceable",
            "in_maintenance",
            "awaiting_parts",
            "annual_inspection",
            "grounded",
            "in_flight",
            "reserved",
            "available"
          ]
        }
      }
    },
    "maintenance_management": {
      "name": "Maintenance Management System",
      "description": "CAA Part 145 compliant maintenance tracking and scheduling",
      "features": {
        "scheduled_maintenance": {
          "name": "Scheduled Maintenance",
          "description": "Tracking of all scheduled maintenance requirements",
          "maintenance_types": [
            {
              "name": "Daily Inspection",
              "interval": "daily",
              "description": "Pre-flight and post-flight inspections"
            },
            {
              "name": "50-Hour Inspection",
              "interval": "50 flight hours",
              "description": "Minor scheduled maintenance check"
            },
            {
              "name": "100-Hour Inspection",
              "interval": "100 flight hours",
              "description": "Comprehensive scheduled maintenance check"
            },
            {
              "name": "Annual Inspection",
              "interval": "12 months",
              "description": "Annual airworthiness review"
            },
            {
              "name": "2,200-Hour Inspection",
              "interval": "2200 flight hours",
              "description": "Major component inspection (Robinson specific)"
            },
            {
              "name": "12-Year Overhaul",
              "interval": "12 years or 2200 hours",
              "description": "Complete overhaul requirement (Robinson specific)"
            },
            {
              "name": "Engine TBO",
              "interval": "varies by engine",
              "description": "Time Between Overhaul for engine"
            }
          ]
        },
        "unscheduled_maintenance": {
          "name": "Unscheduled Maintenance",
          "description": "Tracking of defects, snags, and unscheduled repairs",
          "categories": [
            "defect_rectification",
            "damage_repair",
            "component_replacement",
            "modification",
            "service_bulletin_compliance",
            "airworthiness_directive_compliance"
          ]
        },
        "component_tracking": {
          "name": "Life-Limited Component Tracking",
          "description": "Tracking of components with mandatory replacement intervals",
          "component_categories": [
            {
              "category": "Main Rotor System",
              "components": [
                "main_rotor_blades",
                "main_rotor_hub",
                "pitch_change_bearings",
                "teeter_bearings",
                "blade_bolts"
              ]
            },
            {
              "category": "Tail Rotor System",
              "components": [
                "tail_rotor_blades",
                "tail_rotor_hub",
                "tail_rotor_gearbox",
                "pitch_change_links"
              ]
            },
            {
              "category": "Drive System",
              "components": [
                "main_transmission",
                "tail_rotor_driveshaft",
                "flex_couplings",
                "clutch_assembly"
              ]
            },
            {
              "category": "Engine",
              "components": [
                "engine_assembly",
                "fuel_control_unit",
                "turbine_wheels",
                "compressor_section"
              ]
            },
            {
              "category": "Flight Controls",
              "components": [
                "servo_actuators",
                "push_pull_tubes",
                "bell_cranks",
                "control_linkages"
              ]
            }
          ]
        },
        "work_orders": {
          "name": "Work Order Management",
          "description": "Digital work order creation, tracking, and sign-off",
          "workflow": [
            "work_order_creation",
            "parts_requisition",
            "engineer_assignment",
            "work_in_progress",
            "inspection",
            "quality_assurance",
            "certification",
            "release_to_service"
          ]
        },
        "parts_inventory": {
          "name": "Parts Inventory Management",
          "description": "Tracking of spare parts, rotables, and consumables",
          "features": [
            "stock_levels",
            "reorder_points",
            "part_numbers",
            "approved_suppliers",
            "certification_tracking",
            "shelf_life_monitoring",
            "batch_tracking"
          ]
        }
      }
    },
    "regulatory_compliance": {
      "name": "Regulatory Compliance Management",
      "description": "Tracking and management of aviation regulatory requirements",
      "features": {
        "airworthiness_directives": {
          "name": "Airworthiness Directive Tracking",
          "description": "Monitoring and compliance tracking for ADs",
          "authorities": ["CAA", "EASA", "FAA"],
          "tracking_fields": [
            "ad_number",
            "effective_date",
            "compliance_date",
            "recurring_interval",
            "applicability",
            "compliance_status",
            "compliance_method",
            "documentation"
          ]
        },
        "service_bulletins": {
          "name": "Service Bulletin Management",
          "description": "Tracking of manufacturer service bulletins",
          "categories": [
            "mandatory",
            "alert",
            "recommended",
            "optional"
          ]
        },
        "certification_standards": {
          "name": "Certification Standards",
          "description": "Compliance with aviation certification standards",
          "standards": [
            {
              "code": "Part 145",
              "name": "Approved Maintenance Organisation",
              "authority": "CAA/EASA",
              "description": "Approval to perform aircraft maintenance"
            },
            {
              "code": "Part M",
              "name": "Continuing Airworthiness",
              "authority": "EASA",
              "description": "Requirements for continuing airworthiness management"
            },
            {
              "code": "Part 66",
              "name": "Aircraft Maintenance Licensing",
              "authority": "CAA/EASA",
              "description": "Engineer licensing requirements"
            },
            {
              "code": "Part 147",
              "name": "Maintenance Training Organisation",
              "authority": "CAA/EASA",
              "description": "Approval to provide maintenance training"
            },
            {
              "code": "Part FCL",
              "name": "Flight Crew Licensing",
              "authority": "CAA/EASA",
              "description": "Pilot licensing requirements"
            },
            {
              "code": "Part OPS",
              "name": "Air Operations",
              "authority": "CAA/EASA",
              "description": "Operational requirements for commercial operations"
            }
          ]
        },
        "audit_management": {
          "name": "Audit Management",
          "description": "Internal and external audit tracking",
          "audit_types": [
            "internal_quality_audit",
            "caa_surveillance_audit",
            "easa_audit",
            "insurance_audit",
            "manufacturer_audit"
          ]
        }
      }
    },
    "personnel_management": {
      "name": "Personnel & Certification Management",
      "description": "Management of pilots, engineers, and instructors",
      "features": {
        "pilot_records": {
          "name": "Pilot Records",
          "description": "Comprehensive pilot certification and currency tracking",
          "certifications": [
            {
              "type": "PPL(H)",
              "name": "Private Pilot Licence (Helicopters)",
              "authority": "CAA",
              "validity": "lifetime with currency requirements"
            },
            {
              "type": "CPL(H)",
              "name": "Commercial Pilot Licence (Helicopters)",
              "authority": "CAA",
              "validity": "lifetime with currency requirements"
            },
            {
              "type": "ATPL(H)",
              "name": "Airline Transport Pilot Licence (Helicopters)",
              "authority": "CAA",
              "validity": "lifetime with currency requirements"
            },
            {
              "type": "IR(H)",
              "name": "Instrument Rating (Helicopters)",
              "authority": "CAA",
              "validity": "12 months"
            },
            {
              "type": "Night Rating",
              "name": "Night Rating",
              "authority": "CAA",
              "validity": "lifetime"
            },
            {
              "type": "FI(H)",
              "name": "Flight Instructor (Helicopters)",
              "authority": "CAA",
              "validity": "3 years"
            },
            {
              "type": "Type Rating",
              "name": "Aircraft Type Rating",
              "authority": "CAA",
              "validity": "12 months"
            }
          ],
          "currency_requirements": [
            {
              "requirement": "90-day currency",
              "description": "3 takeoffs and landings in preceding 90 days for passenger carrying"
            },
            {
              "requirement": "Licence Proficiency Check",
              "description": "Annual proficiency check with examiner",
              "interval": "12 months"
            },
            {
              "requirement": "Operator Proficiency Check",
              "description": "Operator-specific competency check",
              "interval": "6-12 months"
            },
            {
              "requirement": "Line check",
              "description": "Observation during normal operations",
              "interval": "12 months"
            }
          ]
        },
        "engineer_records": {
          "name": "Engineer Records",
          "description": "Aircraft maintenance engineer licensing and authorisations",
          "licence_categories": [
            {
              "category": "B1.3",
              "name": "Helicopter Turbine",
              "scope": "Mechanical, electrical, avionics on turbine helicopters"
            },
            {
              "category": "B1.4",
              "name": "Helicopter Piston",
              "scope": "Mechanical, electrical, avionics on piston helicopters"
            },
            {
              "category": "B2",
              "name": "Avionics",
              "scope": "Avionic systems on all aircraft"
            },
            {
              "category": "B3",
              "name": "Light Aircraft",
              "scope": "Piston aircraft up to 2000kg"
            }
          ],
          "type_ratings": [
            "Robinson R22",
            "Robinson R44",
            "Robinson R66",
            "MD 500 Series",
            "Bell 206",
            "Airbus H125",
            "Airbus H135"
          ]
        },
        "medical_certificates": {
          "name": "Medical Certificate Tracking",
          "description": "Aviation medical certificate validity monitoring",
          "certificate_types": [
            {
              "class": "Class 1",
              "validity_under_40": "12 months",
              "validity_40_to_50": "12 months",
              "validity_over_50": "6 months",
              "required_for": "Commercial operations"
            },
            {
              "class": "Class 2",
              "validity_under_40": "60 months",
              "validity_40_to_50": "24 months",
              "validity_over_50": "12 months",
              "required_for": "Private operations"
            },
            {
              "class": "LAPL Medical",
              "validity": "60 months under 40, 24 months over 40",
              "required_for": "Light aircraft private operations"
            }
          ]
        },
        "training_records": {
          "name": "Training Records",
          "description": "Comprehensive training and recurrency tracking",
          "training_types": [
            "initial_type_training",
            "recurrent_training",
            "differences_training",
            "emergency_procedures",
            "crew_resource_management",
            "dangerous_goods",
            "first_aid",
            "security_awareness"
          ]
        }
      }
    },
    "flight_operations": {
      "name": "Flight Operations Management",
      "description": "Planning, scheduling, and recording of flight operations",
      "features": {
        "flight_booking": {
          "name": "Flight Booking System",
          "description": "Aircraft and instructor booking management",
          "booking_types": [
            "training_flight",
            "self_fly_hire",
            "charter",
            "maintenance_flight",
            "ferry_flight",
            "demonstration_flight"
          ]
        },
        "flight_planning": {
          "name": "Flight Planning",
          "description": "Pre-flight planning and documentation",
          "planning_elements": [
            "route_planning",
            "weather_briefing",
            "notam_review",
            "weight_and_balance",
