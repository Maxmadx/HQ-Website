{
  "name": "hq-aviation-website",
  "version": "1.0.0",
  "description": "HQ Aviation - Helicopter Sales, Maintenance & Pilot Training",
  "main": "server.js",
  "scripts": {
    "start": "NODE_ENV=production node server.js",
    "dev": "concurrently \"vite\" \"node server.js\" --names \"vite,api\" --prefix-colors \"cyan,yellow\"",
    "dev:vite": "vite",
    "prebuild": "node scripts/optimize-images.js",
    "build": "vite build",
    "preview": "vite preview",
    "static": "node server.js",
    "test": "vitest run",
    "deploy:server": "docker build --platform linux/amd64 -t europe-west2-docker.pkg.dev/hq-website-4abc7/hq-aviation/server:latest . && docker push europe-west2-docker.pkg.dev/hq-website-4abc7/hq-aviation/server:latest && gcloud run deploy hq-aviation-server --image=europe-west2-docker.pkg.dev/hq-website-4abc7/hq-aviation/server:latest --region=europe-west2"
  },
  "repository": {
    "type": "git",
    "url": ""
  },
  "keywords": [
    "aviation",
    "helicopter",
    "squarespace"
  ],
  "author": "HQ Aviation",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "d3-scale": "^4.0.2",
    "dompurify": "^3.3.3",
    "dotenv": "^17.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.6.1",
    "framer-motion": "^12.38.0",
    "googleapis": "^171.4.0",
    "marked": "^18.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "react-helmet-async": "^3.0.0",
    "react-simple-maps": "^3.0.0",
    "stripe": "^22.0.0",
    "ua-parser-js": "^2.0.9",
    "world-atlas": "^2.0.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "sharp": "^0.34.5",
    "supertest": "^7.2.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.3"
  }
}
